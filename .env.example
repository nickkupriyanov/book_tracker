# Frontend environment variables.
# Copy this file to `.env.local` and adjust values for your setup.

# Storage mode: "local" (default) or "http".
# When unset or empty, the app falls back to localStorage mode and no
# backend is required.
NEXT_PUBLIC_STORAGE_MODE=

# API base URL for HTTP mode. Required only when
# NEXT_PUBLIC_STORAGE_MODE=http.
NEXT_PUBLIC_API_BASE_URL=
